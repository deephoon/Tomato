{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(npm test:*)",
      "Bash(npm test)",
      "Bash(npm ci)",
      "Bash(npm install:*)",
      "Bash(npx vitest:*)",
      "Bash(node --check *)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git ls-files:*)",
      "Bash(git check-ignore:*)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/stop-verify-tests.sh\"",
            "timeout": 120,
            "statusMessage": "Verifying tests before stopping..."
          }
        ]
      }
    ]
  }
}
